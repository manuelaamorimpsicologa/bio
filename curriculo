          <p class="info-label">Atendimento</p>
          <p class="info-val">Online · Adultos · Empresas · Palestras</p>
        </div>
      </div>
    </div>

    <div class="sidebar-card">
      <h4>Competências</h4>
      <div class="skills">
        <span class="skill-tag">Saúde mental no trabalho</span>
        <span class="skill-tag">Psicanálise</span>
        <span class="skill-tag">Psicologia organizacional</span>
        <span class="skill-tag">Avaliação psicossocial</span>
        <span class="skill-tag">Burnout</span>
        <span class="skill-tag">Direitos humanos</span>
        <span class="skill-tag">Pesquisa acadêmica</span>
